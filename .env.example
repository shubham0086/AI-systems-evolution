# Copy to .env (or just export these). Defaults run fully offline in MOCK mode.

# Set to 0 to call a real model instead of the built-in mock.
LLM_MOCK=1

# OpenAI-compatible endpoint. Ollama (free, local) shown by default.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2
LLM_API_KEY=ollama

# The single task every rung runs. Change it and re-run the whole ladder.
TOPIC=the history of the espresso machine
